{
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx sync.ts",
    "summarise": "flock -n .summarise.lock tsx summarise.ts",
    "collect": "tsx recent-headers.ts",
    "prepare": "tsx prepare-articles.ts",
    "pdf": "bash -c 'pandoc newsletters/$0.md -t html --css newsletters/style.css -o newsletters/$0.pdf --pdf-engine=weasyprint'",
    "test": "vitest run"
  },
  "dependencies": {
    "rss-parser": "^3.13.0",
    "tsx": "^4.19.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/turndown": "^5.0.5",
    "vitest": "^4.0.18"
  }
}
